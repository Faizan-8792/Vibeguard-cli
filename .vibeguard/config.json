{
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "vendor/**",
    "third_party/**",
    "third-party/**",
    "takeinspiration/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    ".vibeguard/**",
    ".vibeguard-trash/**"
  ],
  "tags": {
    "customRules": []
  },
  "importance": {
    "weights": {
      "dependents": 5,
      "imports": 2,
      "git": 3,
      "route": 4
    }
  },
  "security": {
    "customSecretPatterns": []
  },
  "context": {
    "defaultRadius": 2,
    "defaultTokenBudget": 12000,
    "models": {
      "claude-3": {
        "tokensPerKiloChar": 280,
        "pricePer1K": 0.003
      },
      "gpt-4": {
        "tokensPerKiloChar": 260,
        "pricePer1K": 0.01
      }
    }
  },
  "clean": {
    "maxChangesPerRun": 50
  },
  "limits": {
    "maxFilesPerRun": 200
  }
}
